# Cloudflare Pages redirect rules. Routes are matched in order; the
# first match wins.
#   301 = permanent same-site redirect (preserves SEO).
#   308 = permanent cross-site redirect (preserves HTTP method).
#
# Locale-prefixed paths (/zh/, /de/) MUST come BEFORE the unprefixed
# EN paths. Cloudflare matches by source-prefix; without this ordering,
# /zh/pricing/foo would match the bare /pricing/* rule and rewrite to
# /editions/foo instead of /zh/editions/foo.
#
# 2026-Q3 architecture correction:
#   - /api/** and /getting-started/** were application-layer docs
#     (Aster Cloud's policy engine REST/GraphQL/WS contracts). They
#     do not belong on aster-lang.dev (CNL language site). Moved to
#     aster-lang.cloud/docs/* (Phase 1 of cloud-docs-subsite plan).
#   - Cross-site 308 to preserve SEO + bookmarks. Cloud subsite uses
#     `localePrefix: 'as-needed'` so EN is bare /docs/* and zh/de
#     carry the prefix.
#
# 2026-Q2 IA refactor (still relevant):
#   - /pricing/* moved under /editions/* (same-site).
#   - /enterprise/* moved under /community/compliance/* (same-site).

# === Pricing → Editions (3-locale mirror, same-site) ===
/zh/pricing               /zh/editions/                       301
/zh/pricing/              /zh/editions/                       301
/zh/pricing/*             /zh/editions/:splat                 301
/de/pricing               /de/editions/                       301
/de/pricing/              /de/editions/                       301
/de/pricing/*             /de/editions/:splat                 301
/pricing                  /editions/                          301
/pricing/                 /editions/                          301
/pricing/*                /editions/:splat                    301

# === Enterprise → Community/Compliance (en-only, same-site) ===
/zh/enterprise            /zh/community/compliance/           301
/zh/enterprise/           /zh/community/compliance/           301
/zh/enterprise/*          /zh/community/compliance/:splat     301
/de/enterprise            /de/community/compliance/           301
/de/enterprise/           /de/community/compliance/           301
/de/enterprise/*          /de/community/compliance/:splat     301
/enterprise               /community/compliance/              301
/enterprise/              /community/compliance/              301
/enterprise/*             /community/compliance/:splat        301

# === Application docs → aster-lang.cloud/docs/* (cross-site) ===
# zh / de come first per the prefix-matching rule.

# /api/* (REST + GraphQL + WebSocket + Audit + Workflows reference)
/zh/api/*  https://aster-lang.cloud/zh/docs/api/:splat        308
/de/api/*  https://aster-lang.cloud/de/docs/api/:splat        308
/api/*     https://aster-lang.cloud/docs/api/:splat           308

# /getting-started/* (auth, quickstart, errors, overview)
/zh/getting-started/*  https://aster-lang.cloud/zh/docs/getting-started/:splat  308
/de/getting-started/*  https://aster-lang.cloud/de/docs/getting-started/:splat  308
/getting-started/*     https://aster-lang.cloud/docs/getting-started/:splat     308

# Legacy /graphql and /websocket roots → Cloud equivalents.
/zh/graphql/*  https://aster-lang.cloud/zh/docs/api/graphql/:splat    308
/de/graphql/*  https://aster-lang.cloud/de/docs/api/graphql/:splat    308
/graphql       https://aster-lang.cloud/docs/api/graphql/overview     308
/graphql/      https://aster-lang.cloud/docs/api/graphql/overview     308
/graphql/*     https://aster-lang.cloud/docs/api/graphql/:splat       308

/zh/websocket/*  https://aster-lang.cloud/zh/docs/api/websocket/:splat  308
/de/websocket/*  https://aster-lang.cloud/de/docs/api/websocket/:splat  308
/websocket       https://aster-lang.cloud/docs/api/websocket/preview   308
/websocket/      https://aster-lang.cloud/docs/api/websocket/preview   308
/websocket/*     https://aster-lang.cloud/docs/api/websocket/:splat    308
